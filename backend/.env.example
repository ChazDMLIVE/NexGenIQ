# NexGenIQ backend configuration template.
#
# Copy this file to ".env" and fill in real values for a deployment.
# The ".env" file itself is git-ignored and must never be committed -
# it holds secrets.
#
# In a hosted deployment (Railway, Render, etc.) set these as the
# platform's environment variables rather than using a file.

# --- Database ---------------------------------------------------------
# Local development: SQLite (zero setup).
NEXGENIQ_DATABASE_URL=sqlite:///./nexgeniq.db
# Production: a managed PostgreSQL connection string, e.g.
# NEXGENIQ_DATABASE_URL=postgresql://user:password@host:5432/nexgeniq

# --- Security ---------------------------------------------------------
# The JWT signing key. CHANGE THIS to a long random string for any real
# deployment - a known key lets anyone forge login tokens. Generate one
# with, for example:  python -c "import secrets; print(secrets.token_hex(32))"
NEXGENIQ_JWT_SECRET=change-me-to-a-long-random-string

# How long an access token stays valid, in minutes (default 12 hours).
NEXGENIQ_ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Application ------------------------------------------------------
# Set to false in production.
NEXGENIQ_DEBUG=true
