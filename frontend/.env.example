# NexGenIQ frontend build-time configuration template.
#
# Copy to ".env" for a local override, or set these as build environment
# variables on the hosting platform. Vite only exposes variables that
# start with VITE_.

# Base URL of the deployed backend API. Leave empty for local development
# (the Vite dev server proxies /api to the local backend automatically).
# For a deployment, set it to the backend's public URL, e.g.:
#   VITE_API_BASE_URL=https://nexgeniq-api.up.railway.app
VITE_API_BASE_URL=
